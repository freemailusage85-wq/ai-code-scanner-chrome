{
  "manifest_version": 3,
  "name": "AI Code Security Scanner",
  "version": "1.0.0",
  "description": "Scan GitHub repositories for security vulnerabilities, hardcoded secrets, and code quality issues — right from your browser.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
